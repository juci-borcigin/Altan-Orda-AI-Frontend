# =============================================================================
# Altan Orda（web）環境変数の雛形
# -----------------------------------------------------------------------------
# 運用: 日常はローカル（npm run dev）で確認 → 問題なければ git push（Vercel が拾う）
# このファイルは Git に含める（秘密は入れない）。実値は web/.env にだけ書く。
#
# ローカルでクレジットを使わずにチャット経路を試す:
#   AO_LLM_DRY_RUN=1  （外部 LLM は呼ばない）
# 実 LLM（OpenRouter）で試す:
#   LLM_API_* を有効化し、AO_LLM_DRY_RUN は 0 または行ごと削除
# =============================================================================

# --- OpenRouter（チャット推奨。3つそろうと OpenRouter 経由になる）---
# LLM_API_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=
# LLM_MODEL=openai/gpt-4.1-mini

# OpenRouter 向け HTTP-Referer（任意だが推奨）
# OPENROUTER_SITE_URL=https://（本番またはプレビューの Vercel URL）

# --- OpenAI（後方互換: LLM_API_* が無いときの直チャット、または Ver2 RAG の埋め込み用キー）---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# --- Tavily（任意。未設定なら web_search ツールは付与されない）---
TAVILY_API_KEY=

# --- ローカル／検証用（外部 LLM を呼ばない）---
# どちらか一方だけ 1 にするのがおすすめ（両方 1 だとモックが先に効く）
AO_LLM_DRY_RUN=
AO_MOCK_LLM=

# --- LLM リクエスト上限（任意。未設定なら 2048）---
LLM_MAX_TOKENS=

# --- Basic Auth（任意。両方そろうと有効）---
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# --- 開発のみ（next dev）: LAN の IP で http://<IP>:3000 を開くときの HMR 許可。ホスト名をカンマ区切り（例: 10.164.74.134）---
# ALLOWED_DEV_ORIGINS=

# --- GDrive（web では未使用）---
# 週次バックアップはリポジトリ直下の GitHub Actions のみが GDrive API を使う。
# 必要なシークレットは docs/operations の実装仕様（GDRIVE_* 等）を参照。
