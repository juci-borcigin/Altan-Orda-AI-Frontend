# LLM（推奨: OpenRouter。ベース URL は /v1 まで含める）
# LLM_API_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=<OpenRouter のキー>
# LLM_MODEL=openai/gpt-5.4-mini

# OpenAI API キー（Ver 2 RAG: text-embedding-3-small 用。チャット用 LLM_API_KEY / OpenRouter とは別キー）
# 未設定時のデフォルトは OpenAI 直チャット（後方互換）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OpenAI 直で別エンドポイントを使う場合のみ
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# LLM_API_KEY / LLM_MODEL / LLM_API_BASE_URL を全部セットすると OpenRouter 等に切り替わる

# OpenRouter 向け HTTP-Referer（ランキング用）。本番は Vercel の URL を設定
OPENROUTER_SITE_URL=https://altan-orda-ai-frontend.vercel.app

# Tavily（/api/chat の web_search ツール。未設定ならツールは付与しない）
TAVILY_API_KEY=

# Basic Auth（Vercel など外部公開時のアクセス制限）
# 例: BASIC_AUTH_USER=juchi / BASIC_AUTH_PASS=***（強いパスワード）
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# Google OAuth（Drive 保存）— GCP コンソールで「ウェブアプリケーション」クライアントを作成し、
# 承認済みリダイレクト URI に次を登録:
#   - ローカル: http://localhost:3000/api/auth/google/callback
#   - 本番:     https://<Cloud-Run-URL>/api/auth/google/callback
# 有効化 API: Google Drive API
# OAuth スコープはコード上「Google ドライブ全体」(drive)。既存の手作りフォルダを一覧に載せるため。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# refresh_token 暗号化用（長いランダム文字列を推奨）
AO_SESSION_SECRET=

# 任意: 「Logs」フォルダの ID を直指定すると Projects/... の探索をスキップ（Drive の URL の id=...）
# GOOGLE_DRIVE_LOGS_FOLDER_ID=
